{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "declarationDir": "dist",
    "sourceMap": true,
    "types": ["bun-types"]
  },
  "include": ["index.ts", "dictionary.ts", "declarations.d.ts"],
  "exclude": ["node_modules", "dist"]
}
