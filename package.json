{
  "name": "@darylcecile/simple-spellchecker",
  "version": "1.0.0",
  "description": "A simple spellchecker with spelling suggestions (ESM fork)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "dict/",
    "index.ts",
    "dictionary.ts",
    "declarations.d.ts",
    "license.txt"
  ],
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node --sourcemap=external --format esm --packages external && tsc --emitDeclarationOnly",
    "test": "bun test"
  },
  "repository": {
    "url": "https://github.com/darylcecile/simple-spellchecker"
  },
  "keywords": [
    "simple",
    "spell",
    "checker",
    "provider",
    "spellcheck",
    "esm",
    "typescript"
  ],
  "author": "JFMDev",
  "license": "MPL-2.0",
  "bugs": {
    "url": "https://github.com/darylcecile/simple-spellchecker/issues"
  },
  "homepage": "https://github.com/darylcecile/simple-spellchecker#readme",
  "dependencies": {
    "adm-zip": "^0.5.4",
    "binarysearch": "^0.2.4",
    "damerau-levenshtein": "^1.0.5",
    "tmp": "^0.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.0",
    "@types/bun": "latest",
    "@types/tmp": "^0.2.0",
    "typescript": "^5.0.0"
  }
}
